# ---------------------------------------------------------------------------
# Dr. Sibi's Dental Care and Implant Center — environment configuration
# Copy this file to `.env.local` and fill in real values before deploying.
# Never commit `.env.local`. Credentials are only ever read on the server.
# ---------------------------------------------------------------------------

# Where appointment requests are emailed (clinic inbox). REQUIRED for email delivery.
APPOINTMENT_RECEIVER_EMAIL=

# Address appointment emails are sent FROM (must be a verified sender on your provider).
APPOINTMENT_SENDER_EMAIL=

# Transactional email provider API key (example: Resend). Server-only, never exposed.
EMAIL_PROVIDER_API_KEY=

# Optional: database connection string if you choose to persist requests.
DATABASE_URL=

# Public site origin (used for canonical URLs, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://drsibidental.com

# Official Google Maps link for the clinic (replace with the verified place URL).
NEXT_PUBLIC_GOOGLE_MAPS_URL=

# Instagram profile URL.
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/kvsibikumar
